<?xml version="1.0" encoding="UTF-8"?>

<Configuration status="WARN">

    <Appenders>

        <Console name="Console">

            <PatternLayout
                    pattern="%d %p %c [%t] %m%n"/>

        </Console>

        <File
                name="FileLogger"
                fileName="logs/framework.log">

            <PatternLayout
                    pattern="%d %p %c [%t] %m%n"/>

        </File>

    </Appenders>

    <Loggers>

        <Root level="info">

            <AppenderRef ref="Console"/>

            <AppenderRef ref="FileLogger"/>

        </Root>

    </Loggers>

</Configuration>